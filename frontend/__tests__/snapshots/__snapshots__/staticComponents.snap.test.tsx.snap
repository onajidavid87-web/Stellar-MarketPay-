          </td>
          <td
            class="py-2.5 text-amber-200/90"
          >
            Toggle bookmark on focused job
          </td>
        </tr>
      </tbody>
    </table>
    <p
      class="mt-5 text-xs text-amber-800"
    >
      Shortcuts are disabled while typing in form fields.
    </p>
  </div>
</div>
`;


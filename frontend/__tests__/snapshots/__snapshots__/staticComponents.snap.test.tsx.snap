    aria-label="Close keyboard shortcuts"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm"
    type="button"
  />
  <div
    class="relative w-full max-w-xl rounded-2xl border border-market-500/20 bg-ink-900 p-6 shadow-2xl"
  >
    <div
      class="mb-4 flex items-center justify-between"
    >
      <h2
        class="font-display text-xl font-bold text-amber-100"
        id="shortcuts-title"
      >
        Keyboard Shortcuts
      </h2>
      <button
        class="btn-ghost px-3 py-1 text-xs"
        type="button"
      >
        Close
      </button>
    </div>
    <table
      class="w-full text-sm"
    >
      <thead>
        <tr
          class="border-b border-market-500/10 text-left text-xs uppercase tracking-wide text-amber-800"
        >
          <th
            class="pb-2 pr-4"
          >
            Key
          </th>
          <th
            class="pb-2"
          >
            Action
          </th>
        </tr>
      </thead>
      <tbody
        class="divide-y divide-market-500/10"
      >
        <tr>
          <td
            class="py-2.5 pr-4"
          >
            <kbd
              class="rounded border border-market-500/25 bg-ink-800 px-2 py-1 text-xs font-semibold text-market-300"
            >
              G
            </kbd>
          </td>
          <td
            class="py-2.5 text-amber-200/90"
          >
            Go to Jobs listing
          </td>
        </tr>
        <tr>
          <td
            class="py-2.5 pr-4"
          >
            <kbd
              class="rounded border border-market-500/25 bg-ink-800 px-2 py-1 text-xs font-semibold text-market-300"
            >
              D
            </kbd>
          </td>
          <td
            class="py-2.5 text-amber-200/90"
          >
            Go to Dashboard
          </td>
        </tr>
        <tr>
          <td
            class="py-2.5 pr-4"
          >
            <kbd
              class="rounded border border-market-500/25 bg-ink-800 px-2 py-1 text-xs font-semibold text-market-300"
            >
              P
            </kbd>
          </td>
          <td
            class="py-2.5 text-amber-200/90"
          >
            Post a new job
          </td>
        </tr>
        <tr>
          <td
            class="py-2.5 pr-4"
          >
            <kbd
              class="rounded border border-market-500/25 bg-ink-800 px-2 py-1 text-xs font-semibold text-market-300"
            >
              ?
            </kbd>
          </td>
          <td
            class="py-2.5 text-amber-200/90"
          >
            Show this shortcut guide
          </td>
        </tr>
        <tr>
          <td
            class="py-2.5 pr-4"
          >
            <kbd
              class="rounded border border-market-500/25 bg-ink-800 px-2 py-1 text-xs font-semibold text-market-300"
            >
              Esc
            </kbd>
          </td>
          <td
            class="py-2.5 text-amber-200/90"
          >
            Close modal / dialog
          </td>
        </tr>
        <tr>
          <td
            class="py-2.5 pr-4"
          >
            <kbd
              class="rounded border border-market-500/25 bg-ink-800 px-2 py-1 text-xs font-semibold text-market-300"
            >
              /
            </kbd>
          </td>
          <td
            class="py-2.5 text-amber-200/90"
          >
            Focus search bar
          </td>
        </tr>
        <tr>
          <td
            class="py-2.5 pr-4"
          >
            <kbd
              class="rounded border border-market-500/25 bg-ink-800 px-2 py-1 text-xs font-semibold text-market-300"
            >
              B
